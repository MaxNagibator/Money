@if (ChildContent != null)
{
    @ChildContent
}

@if (!IsOpen)
{
    return;
}

<MudPopover AnchorOrigin="Origin.BottomLeft"
            Class="mt-4 mx-4 pa-4 pop-over"
            Open="IsOpen"
            TransformOrigin="Origin.TopLeft">
    <EditForm Model="@Input"
              @ref="_editForm"
              OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />

        <MudGrid>
            <MudItem md="6"
                     xs="12">
                <SmartSum @ref="_smartSum"
                          IsAutoFocus="_isAutoFocus"
                          GetInitialSum="() => _sum" />
            </MudItem>
            <MudItem md="6"
                     xs="12">
                <SmartDatePicker @ref="_smartDatePicker"
                                 @bind-Date="Input.Date"
                                 For="@(() => Input.Date)"
                                 GetInitialDate="() => Input.Date" />
            </MudItem>
            <MudItem md="6"
                     xs="12">
                <SmartCategory @bind-Value="Input.Category"
                               For="@(() => Input.Category)"
                               Options="Input.CategoryList ?? []" />

                @if (_suggestedCategory != null && Input.Category == _suggestedCategory)
                {
                    <MudChip T="string"
                             Color="Color.Tertiary"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Rounded.AutoAwesome"
                             OnClose="@(_ => ClearSuggestion())"
                             Class="mt-1">
                        Подставлено: @_suggestedCategory.Name
                    </MudChip>
                }
            </MudItem>
            <MudItem md="6"
                     xs="12">
                <SmartPlace @bind-Value="Input.Place"
                            For="@(() => Input.Place)"
                            OnCommitted="OnPlaceCommittedAsync" />
            </MudItem>
            <MudItem md="12"
                     xs="12">
                <MudTextField AdornmentColor="Color.Tertiary"
                              AdornmentIcon="@Icons.Material.Rounded.Comment"
                              Sizing="InputSizing.Auto"
                              @bind-Value="Input.Comment"
                              Counter="0"
                              For="@(() => Input.Comment)"
                              Label="Комментарий" />
            </MudItem>
        </MudGrid>

        <MudStack AlignItems="AlignItems.Center"
                  Class="mt-3"
                  Justify="Justify.SpaceBetween"
                  Row>
            <MudButton Color="Color.Error"
                       OnClick=" () => ToggleOpen()">
                Закрыть
            </MudButton>
            <MudButton OnClick="SubmitAsync"
                       Color="Color.Tertiary"
                       Variant="Variant.Filled">
                Сохранить
            </MudButton>
        </MudStack>
    </EditForm>
</MudPopover>

<style>
    .pop-over {
        max-width: 600px !important;
    }
</style>
